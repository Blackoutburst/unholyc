#include <uhcio.uhh>
#include <uhcstd.uhh>
#include <uhcnet.uhh>

U0 onClient(TcpClient.It* client) {
    I8 buffer[1024];
    while (TcpServer.read(*client, buffer, sizeof(buffer))) {
        Log.msg("Received: %s", buffer);
        TcpServer.write(*client, buffer, sizeof(buffer));
    }
}

void* serverThread(void* arg) {
    TcpServer.It* server = (TcpServer.It*)arg;
    TcpServer.listen(*server, onClient);
    
    return NULL;
}

I32 main() {
    TcpServer.It server = TcpServer.create(12345, 10);
    Thread.It t = Thread.start(serverThread, &server);

    while (1) {
        // Do shit on main thread
    }
    
    Thread.join(t);
    TcpServer.destroy(server);

    return 0;
}
