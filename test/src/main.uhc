#include <uhcio.uhh>
#include <uhcstd.uhh>

U0* asyncStuff(U0* arg) {
    U0 (*func)() = *(U0 (**)())arg;
    func();

    return NULL;
}

U0 io(lambda () -> U0) {
    Thread.It t = Thread.start(asyncStuff, &func);
    Thread.join(t);
}

I32 main() {
    io() { 
        Log.msg("Other thread"); 
    };

    Log.msg("Main thread");

    return 0;
}
