#include <stdlib.h>

#include <uhcmath.uhh>

#include "core/swapchain.uhh"
#include "core/device.uhh"
#include "core/semaphore.uhh"
#include "utils/utils.uhh"

static U0 createDepthImage(UgContext.It& ctx, UgSwapchain.It& swapchain) {
    VkExtent2D ext = UgSwapchain.extend(ctx, swapchain);

    VkImageCreateInfo imageInfo;
    imageInfo.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
    imageInfo.pNext = NULL;
    imageInfo.flags = 0;
    imageInfo.imageType = VK_IMAGE_TYPE_2D;
    imageInfo.format = VK_FORMAT_D32_SFLOAT;
    imageInfo.extent = { ext.width, ext.height, 1 };
    imageInfo.mipLevels = 1;
    imageInfo.arrayLayers = 1;
    imageInfo.samples = VK_SAMPLE_COUNT_1_BIT;
    imageInfo.tiling = VK_IMAGE_TILING_OPTIMAL;
    imageInfo.usage = VK_IMAGE_USAGE_DEPTH_STENCIL_ATTACHMENT_BIT;
    imageInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
    imageInfo.queueFamilyIndexCount = 0;
    imageInfo.pQueueFamilyIndices = NULL;
    imageInfo.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
    vkCreateImage(ctx.device.handle, &imageInfo, NULL, &swapchain.depthImage);

    VkMemoryRequirements memReqs;
    vkGetImageMemoryRequirements(ctx.device.handle, swapchain.depthImage, &memReqs);

    VkMemoryAllocateInfo allocInfo;
    allocInfo.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO;
    allocInfo.pNext = NULL;
    allocInfo.allocationSize = memReqs.size;
    allocInfo.memoryTypeIndex = UgUtils.findMemoryType(ctx, memReqs.memoryTypeBits, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
    vkAllocateMemory(ctx.device.handle, &allocInfo, NULL, &swapchain.depthImageMemory);
    vkBindImageMemory(ctx.device.handle, swapchain.depthImage, swapchain.depthImageMemory, 0);

    swapchain.depthImageView = UgImageView.makeView(ctx, swapchain.depthImage, VK_FORMAT_D32_SFLOAT, VK_IMAGE_ASPECT_DEPTH_BIT);
}

namespace UgSwapchain {
    VkExtent2D extend(UgContext.It& ctx, UgSwapchain.It& swapchain) {
        if (swapchain.capabilities.currentExtent.width != 0xFFFFFFFF)
            return swapchain.capabilities.currentExtent;

        I32 width = 0;
        I32 height = 0;
        glfwGetFramebufferSize(ctx.window.handle, &width, &height);

        I32 minWidth = swapchain.capabilities.minImageExtent.width;
        I32 minHeight = swapchain.capabilities.minImageExtent.height;

        I32 maxWidth = swapchain.capabilities.maxImageExtent.width;
        I32 maxHeight = swapchain.capabilities.maxImageExtent.height;

        return {
            (U32)(Math.clamp(width, minWidth, maxWidth)),
            (U32)(Math.clamp(height, minHeight, maxHeight))
        };
    }

    U0 update(UgContext.It& ctx, UgSwapchain.It& swapchain, VkCommandBuffer cmd) {
        VkExtent2D ext = extend(ctx, swapchain);

        VkViewport viewport;
        viewport.x = 0.0f;
        viewport.y = 0.0f;
        viewport.width = (F32)ext.width;
        viewport.height = (F32)ext.height;
        viewport.minDepth = 0.0f;
        viewport.maxDepth = 1.0f;
        vkCmdSetViewport(cmd, 0, 1, &viewport);

        VkRect2D scissor;
        scissor.offset = {0, 0};
        scissor.extent = ext;
        vkCmdSetScissor(cmd, 0, 1, &scissor);
    }

    U0 destroy(UgContext.It& ctx, UgSwapchain.It& swapchain) {
        for (U32 i = 0; i < swapchain.imageCount; i++) {
            UgImageView.destroy(ctx, swapchain.imageViews[i]);
            UgSemaphore.destroy(ctx, swapchain.pSemaphore[i]);
            UgSemaphore.destroy(ctx, swapchain.rSemaphore[i]);
        }

        vkDestroyImageView(ctx.device.handle, swapchain.depthImageView, NULL);
        vkDestroyImage(ctx.device.handle, swapchain.depthImage, NULL);
        vkFreeMemory(ctx.device.handle, swapchain.depthImageMemory, NULL);

        free(swapchain.imageViews);
        free(swapchain.pSemaphore);
        free(swapchain.rSemaphore);

        vkDestroySwapchainKHR(ctx.device.handle, swapchain.handle, NULL);
    }

    UgSwapchain.It create(UgContext.It& ctx) {
        UgSwapchain.It swapchain;
        swapchain.currentFrame = 0;
        swapchain.imageIndex = 0;

        VkSurfaceCapabilitiesKHR capabilities;
        vkGetPhysicalDeviceSurfaceCapabilitiesKHR(ctx.physicalDevice, ctx.surface, &capabilities);
        swapchain.capabilities = capabilities;

        U32 formatCount = 0;
        vkGetPhysicalDeviceSurfaceFormatsKHR(ctx.physicalDevice, ctx.surface, &formatCount, NULL);
        VkSurfaceFormatKHR* surfaceFormats = (VkSurfaceFormatKHR*)malloc(sizeof(VkSurfaceFormatKHR) * formatCount);
        vkGetPhysicalDeviceSurfaceFormatsKHR(ctx.physicalDevice, ctx.surface, &formatCount, surfaceFormats);

        for (U32 i = 0; i < formatCount; i++) {
            if (surfaceFormats[i].format == VK_FORMAT_B8G8R8A8_UNORM && surfaceFormats[i].colorSpace == VK_COLOR_SPACE_SRGB_NONLINEAR_KHR) {
                swapchain.surfaceFormat = surfaceFormats[i];
                break;
            }
        }
        free(surfaceFormats);

        U32 presentModeCount = 0;
        vkGetPhysicalDeviceSurfacePresentModesKHR(ctx.physicalDevice, ctx.surface, &presentModeCount, NULL);
        VkPresentModeKHR* presentModes = (VkPresentModeKHR*)malloc(sizeof(VkPresentModeKHR) * presentModeCount);
        vkGetPhysicalDeviceSurfacePresentModesKHR(ctx.physicalDevice, ctx.surface, &presentModeCount, presentModes);

        swapchain.presentMode = VK_PRESENT_MODE_FIFO_KHR;
        for (U32 i = 0; i < presentModeCount; i++) {
            if (presentModes[i] == VK_PRESENT_MODE_MAILBOX_KHR) {
                swapchain.presentMode = VK_PRESENT_MODE_MAILBOX_KHR; 
                break;
            }
        }
        free(presentModes);

        VkExtent2D extent = extend(ctx, swapchain);

        U32 imageCount = capabilities.minImageCount + 1;
        if (capabilities.maxImageCount > 0 && imageCount > capabilities.maxImageCount) {
            imageCount = capabilities.maxImageCount;
        }
        swapchain.imageCount = imageCount;

        VkSwapchainCreateInfoKHR createInfo;
        createInfo.sType = VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR;
        createInfo.pNext = NULL;
        createInfo.flags = 0;
        createInfo.surface = ctx.surface;
        createInfo.minImageCount = imageCount;
        createInfo.imageFormat = swapchain.surfaceFormat.format;
        createInfo.imageColorSpace = swapchain.surfaceFormat.colorSpace;
        createInfo.imageExtent = extent;
        createInfo.imageArrayLayers = 1;
        createInfo.imageUsage = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT;

        U32 queues[2] = {
            UgQueueFamilies.getType(ctx.physicalDevice, VK_QUEUE_GRAPHICS_BIT),
            UgDevice.getSurfaceSupport(ctx.physicalDevice, ctx.surface)
        };

        U8 sameQueue = queues[0] == queues[1];

        if (sameQueue) {
            createInfo.imageSharingMode = VK_SHARING_MODE_EXCLUSIVE;
            createInfo.queueFamilyIndexCount = 0;
            createInfo.pQueueFamilyIndices = NULL;
        } else {
            createInfo.imageSharingMode = VK_SHARING_MODE_CONCURRENT;
            createInfo.queueFamilyIndexCount = 2;
            createInfo.pQueueFamilyIndices = queues;
        }

        createInfo.preTransform = capabilities.currentTransform;
        createInfo.compositeAlpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR;
        createInfo.presentMode = swapchain.presentMode;
        createInfo.clipped = VK_TRUE;
        createInfo.oldSwapchain = VK_NULL_HANDLE;

        vkCreateSwapchainKHR(ctx.device.handle, &createInfo, NULL, &swapchain.handle);

        VkImage* rawImages = (VkImage*)malloc(sizeof(VkImage) * imageCount);
        vkGetSwapchainImagesKHR(ctx.device.handle, swapchain.handle, &imageCount, rawImages);

        UgImageView.It* imageViews = (UgImageView.It*)malloc(sizeof(UgImageView.It) * imageCount);
        UgSemaphore.It* pSemaphore = (UgSemaphore.It*)malloc(sizeof(UgSemaphore.It) * imageCount);
        UgSemaphore.It* rSemaphore = (UgSemaphore.It*)malloc(sizeof(UgSemaphore.It) * imageCount);

        for (U32 i = 0; i < imageCount; i++) {
            imageViews[i] = UgImageView.create(ctx, rawImages[i], swapchain.surfaceFormat.format);
            pSemaphore[i] = UgSemaphore.create(ctx);
            rSemaphore[i] = UgSemaphore.create(ctx);
        }
        free(rawImages);

        swapchain.imageViews = imageViews;
        swapchain.pSemaphore = pSemaphore;
        swapchain.rSemaphore = rSemaphore;

        createDepthImage(ctx, swapchain);

        return swapchain;
    }
}
